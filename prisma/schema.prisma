generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Race {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  updatedAt    DateTime      @updatedAt
  scrapedAt    DateTime
  rerollCost   Int           @default(0)
  imageUrl     String?
  participants Participant[]
  positions    Position[]
}

model Position {
  id            Int             @id @default(autoincrement())
  raceId        Int
  name          String
  cost          Int
  ma            Int
  st            Int
  ag            Int
  pa            Int?
  av            Int
  updatedAt     DateTime        @updatedAt
  scrapedAt     DateTime
  race          Race            @relation(fields: [raceId], references: [id])
  skills        PositionSkill[]
  rosterEntries RosterEntry[]
}

model Skill {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  category          String
  description       String
  updatedAt         DateTime           @updatedAt
  scrapedAt         DateTime
  positions         PositionSkill[]
  rosterEntrySkills RosterEntrySkill[]
}

model PositionSkill {
  positionId Int
  skillId    Int
  position   Position @relation(fields: [positionId], references: [id])
  skill      Skill    @relation(fields: [skillId], references: [id])

  @@id([positionId, skillId])
}

model Tournament {
  id                 Int              @id @default(autoincrement())
  name               String
  edition            String
  year               Int
  startDate          DateTime
  description        String?
  status             TournamentStatus @default(ACTIVE)
  format             TournamentFormat @default(MIXED)
  groupCount         Int?
  qualifiersPerGroup Int?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  participants       Participant[]
  rounds             Round[]

  @@unique([name, year])
}

model Player {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  participants Participant[]
}

model Participant {
  id            Int             @id @default(autoincrement())
  playerId      Int
  tournamentId  Int
  raceId        Int
  teamName      String?
  groupNumber   Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  hasApothecary     Boolean         @default(false)
  rerolls           Int             @default(0)
  teamValue         Int             @default(0)
  isVeteran         Boolean         @default(false)
  cheerleaders      Int             @default(0)
  assistantCoaches  Int             @default(0)
  fanFactor         Int             @default(0)
  treasury          Int             @default(1000000)
  awayMatches   Match[]         @relation("AwayParticipant")
  homeMatches   Match[]         @relation("HomeParticipant")
  player        Player          @relation(fields: [playerId], references: [id])
  race          Race            @relation(fields: [raceId], references: [id])
  tournament    Tournament      @relation(fields: [tournamentId], references: [id])
  roster        RosterEntry[]
  rosterHistory RosterHistory[]

  @@unique([playerId, tournamentId])
}

model RosterEntry {
  id            Int                @id @default(autoincrement())
  participantId Int
  positionId    Int
  playerName    String?
  spp           Int                @default(0)
  injured       Boolean            @default(false)
  mvUp          Int                @default(0)
  stUp          Int                @default(0)
  agUp          Int                @default(0)
  paUp          Int                @default(0)
  avUp          Int                @default(0)
  participant   Participant        @relation(fields: [participantId], references: [id])
  position      Position           @relation(fields: [positionId], references: [id])
  skills        RosterEntrySkill[]
}

model RosterEntrySkill {
  rosterEntryId Int
  skillId       Int
  rosterEntry   RosterEntry @relation(fields: [rosterEntryId], references: [id])
  skill         Skill       @relation(fields: [skillId], references: [id])

  @@id([rosterEntryId, skillId])
}

model RosterHistory {
  id            Int         @id @default(autoincrement())
  participantId Int
  snapshot      Json
  changedAt     DateTime    @default(now())
  reason        String?
  participant   Participant @relation(fields: [participantId], references: [id])
}

model Round {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  number       Int
  phase        RoundPhase
  createdAt    DateTime   @default(now())
  matches      Match[]
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
}

model Match {
  id                Int          @id @default(autoincrement())
  roundId           Int
  homeParticipantId Int?
  awayParticipantId Int?
  homeTDs           Int?
  awayTDs           Int?
  homeCas           Int?
  awayCas           Int?
  homeGold          Int?
  awayGold          Int?
  status            MatchStatus  @default(PENDING)
  winnerId          Int?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  awayParticipant   Participant? @relation("AwayParticipant", fields: [awayParticipantId], references: [id])
  homeParticipant   Participant? @relation("HomeParticipant", fields: [homeParticipantId], references: [id])
  round             Round        @relation(fields: [roundId], references: [id])
}

enum TournamentStatus {
  ACTIVE
  COMPLETED
}

enum TournamentFormat {
  MIXED
  SINGLE_ELIMINATION
  ROUND_ROBIN
}

enum RoundPhase {
  GROUP_STAGE
  ELIMINATION
}

enum MatchStatus {
  PENDING
  COMPLETED
}
